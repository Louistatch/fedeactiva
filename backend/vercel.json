{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install --production=false",
  "functions": {
    "api/index.js": {
      "memory": 3008,
      "maxDuration": 30,
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
