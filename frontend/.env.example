# FedeActiva Frontend Environment Variables

# API Configuration
VITE_API_URL=https://api.fedeactiva.tg
VITE_APP_NAME=FedeActiva

# Payment Providers (for widget)
VITE_FEDAPAY_PUBLIC_KEY=your_fedapay_public_key_here
VITE_CINETPAY_PUBLIC_KEY=your_cinetpay_public_key_here

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=true

# Widget Configuration
VITE_WIDGET_VERSION=2.0.0
